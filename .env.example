DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maplestory_reborn_tools?schema=public"
# 无本地 PostgreSQL 或使用 Prisma Accelerate 时，设为 true 直接读取 JSON/演示数据
USE_LOCAL_DATA="true"
# 生产站点地址，用于 sitemap / Open Graph（部署后改成你的域名）
NEXT_PUBLIC_SITE_URL="https://www.mxdxs.icu"

# 悬浮运营位（全站右下角，/quiz 页自动隐藏）
# NEXT_PUBLIC_HOME_PROMO_ENABLED="true"
# NEXT_PUBLIC_HOME_PROMO_HREF="/quiz"
# NEXT_PUBLIC_HOME_PROMO_IMAGE="/promo/quiz-float.gif"
# NEXT_PUBLIC_HOME_PROMO_IMAGE_WIDTH="144"
# NEXT_PUBLIC_HOME_PROMO_IMAGE_HEIGHT="144"
# NEXT_PUBLIC_HOME_PROMO_ALT="职业本命测试"
# NEXT_PUBLIC_HOME_PROMO_NEW_TAB="false"
